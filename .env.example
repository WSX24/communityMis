NODE_ENV=production
SERVICE_NAME=community-mis-backend
BIND_HOST=127.0.0.1
BACKEND_PORT=3001
FRONTEND_PORT=5173

AUTH_STORE=mysql
AUTH_SESSION_SECRET=replace-with-at-least-32-random-bytes
AUTH_SESSION_TTL_MS=86400000
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=Lax

CORS_ORIGIN=https://example.com

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=community_mis
DB_PASSWORD=replace-with-db-password
DB_NAME=community_mis
DB_CONNECTION_LIMIT=10

UPLOAD_ROOT=/var/lib/community-mis/uploads
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
UPLOAD_ALLOWED_EXTENSIONS=.png,.jpg,.jpeg,.webp,.gif,.pdf,.txt,.doc,.docx

SMS_PROVIDER=aliyun
ALIYUN_ACCESS_KEY_ID=replace-with-access-key-id
ALIYUN_ACCESS_KEY_SECRET=replace-with-access-key-secret
ALIYUN_SMS_SIGN_NAME=replace-with-sign-name
ALIYUN_SMS_TEMPLATE_CODE=replace-with-template-code

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="邻帮 <mailer@example.com>"
SMTP_SECURE=false

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-openai-compatible-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=15000
